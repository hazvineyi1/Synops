# ============================================================================
# Praxis LMS — environment configuration
# ============================================================================
# Praxis is a self-contained pnpm workspace under praxis/, deployed as its own
# Railway service (Dockerfile.praxis / railway.praxis.json). Copy to `.env` for
# local dev; in production set these as Railway service variables. The server
# fails fast at boot if a REQUIRED value is missing.
# ----------------------------------------------------------------------------

# --- Core (REQUIRED) --------------------------------------------------------

# Postgres connection string (thrown at import if missing).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the server binds to. Railway injects this at runtime.
PORT=8080

# --- Runtime / ops ----------------------------------------------------------

# Set to "production" in production. The Dockerfile pins this.
NODE_ENV=production

# Log verbosity: trace | debug | info | warn | error. Defaults to "info".
LOG_LEVEL=info

# Public URL of this deployment (used in emails / links).
# APP_URL=https://praxis.yourdomain.com
# PUBLIC_APP_URL=https://praxis.yourdomain.com

# --- AI tutor / coach (OPTIONAL — degrades to non-AI when unset) ------------
# Anthropic-compatible backend for the Socratic tutor and coach.
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-...

# --- Error monitoring (OPTIONAL — no-op without a DSN) -----------------------
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- File storage (OPTIONAL — Supabase Storage) -----------------------------
# Required only for upload features; those endpoints 400 with a clear message
# when unset (see lib/supabaseStorage.ts).
# SUPABASE_URL=https://xyz.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...
# SUPABASE_BUCKET=praxis-uploads

# --- Email (OPTIONAL — Resend) ----------------------------------------------
# RESEND_API_KEY=re_...
# EMAIL_FROM=Praxis <noreply@yourdomain.com>

# --- WhatsApp / SMS (OPTIONAL — Twilio) -------------------------------------
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WEBHOOK_URL=https://praxis.yourdomain.com/api/whatsapp/webhook

# --- Coach cross-service link (OPTIONAL) ------------------------------------
# COACH_API_URL=https://coach.yourdomain.com
# COACH_API_KEY=...

# --- Development only --------------------------------------------------------
# Demo/dev login helpers. NEVER enable in production.
# ENABLE_DEMO_LOGIN=true
# DEMO_LOGIN_HOSTS=localhost
# ENABLE_DEV_ROUTES=true
