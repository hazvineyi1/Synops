# ============================================================================
# Paideia stack — environment configuration
# ============================================================================
# The Paideia Railway service (Dockerfile.paideia / railway.paideia.json) serves
# the marketing site + Coach (study) + teacher app + the shared API, and can
# also host the Compass Curriculum Builder at /builder/. Copy to `.env` for local
# dev; in production set these as Railway service variables. The server fails
# fast at boot if a REQUIRED value is missing.
# ----------------------------------------------------------------------------

# --- Core (REQUIRED) --------------------------------------------------------

# Postgres connection string (thrown at import if missing).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the server binds to. Railway injects this at runtime.
PORT=8080

# OpenAI-compatible AI backend that powers tutoring + grading. BOTH are required
# (see artifacts/paideia-api/src/lib/openai.ts) or the server refuses to boot.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# --- Runtime / ops ----------------------------------------------------------

# Set to "production" in production (enables secure cookies, HSTS, same-origin
# CORS). The Dockerfile pins this, but set it for local prod-like runs.
NODE_ENV=production

# Optional error monitoring (no-op without a DSN).
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=production

# --- Compass Curriculum Builder mount (OPTIONAL) ----------------------------
# The /builder/ API stays dormant unless BOTH are set. Compass MUST use its own
# database (its table names collide with the host schema).
# SESSION_SECRET=a-long-random-string
# COMPASS_DATABASE_URL=postgresql://user:password@host:5432/compass_db

# --- Billing rails (OPTIONAL — degrade gracefully when unset) ----------------
# Stripe (cards, subscriptions):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# Flutterwave (African card / mobile money). FLUTTERWAVE_SECRET_HASH verifies
# the verif-hash webhook header.
# FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
# FLUTTERWAVE_SECRET_HASH=your-chosen-secret-hash
# Paynow (Zimbabwe mobile money):
# PAYNOW_INTEGRATION_ID=...
# PAYNOW_INTEGRATION_KEY=...
# Gate paid plans on/off in the UI:
# PAID_PLANS_ENABLED=true
# Allow the built-in mock billing provider (blocked in production unless true):
# BILLING_ALLOW_MOCK=false

# --- Email (OPTIONAL — Resend) ----------------------------------------------
# RESEND_API_KEY=re_...
# EMAIL_FROM=Paideia <noreply@yourdomain.com>

# --- WhatsApp / SMS notifications (OPTIONAL — Twilio) ------------------------
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Misc (OPTIONAL) --------------------------------------------------------
# Comma-separated admin emails.
# ADMIN_EMAILS=you@example.com
# Hostnames that should serve the Coach (study) app as the site root.
# COACH_HOSTS=coach.yourdomain.com
# Salt for hashing IPs in analytics (set a stable random value in production).
# ANALYTICS_IP_SALT=change-me
# Secret used to sign learner magic links.
# LEARNER_LINK_SECRET=change-me
# Absolute URL of the study app (used in emails / links).
# STUDY_APP_URL=https://yourdomain.com/study
