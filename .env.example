# ============================================================================
# The Coach — environment configuration
# ============================================================================
# Copy this file to `.env` for local development and fill in real values.
# In production (Railway), set these as service variables instead of a file.
# The server validates these at startup (see artifacts/api-server/src/lib/config.ts)
# and refuses to boot if a required value is missing.
# ----------------------------------------------------------------------------

# --- Core (REQUIRED) --------------------------------------------------------

# Postgres connection string. Railway's Postgres plugin provides this.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic API key — powers the coach. Without it, the product does nothing.
ANTHROPIC_API_KEY=sk-ant-...

# Clerk authentication keys (https://dashboard.clerk.com → API Keys).
# The publishable key must ALSO be passed as a build arg to the frontend
# (VITE_CLERK_PUBLISHABLE_KEY) because Vite inlines it at build time.
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Port the server binds to. Railway injects this automatically at runtime;
# set it explicitly for local dev.
PORT=8080

# --- Frontend build-time (REQUIRED at build) --------------------------------
# Vite inlines VITE_* values when `vite build` runs, so these must be present
# in the build environment (Railway: set as build variables). VITE_CLERK_PROXY_URL
# is optional and only needed if you front Clerk through a proxy domain.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# VITE_CLERK_PROXY_URL=https://clerk.yourdomain.com

# --- Runtime / ops ----------------------------------------------------------

# Set to "production" in production. Controls logging format, HSTS, error
# message verbosity, and the ENABLE_TEST_LOGIN safety check.
NODE_ENV=production

# Log verbosity: trace | debug | info | warn | error. Defaults to "info".
LOG_LEVEL=info

# Comma-separated list of web origins allowed to call the API cross-origin.
# Leave unset if the frontend is served from the same origin as the API (the
# default deployment) — same-origin requests never need this. APP_URL is used
# as a fallback if ALLOWED_ORIGINS is unset.
# ALLOWED_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
# APP_URL=https://app.yourdomain.com

# Comma-separated admin emails (already set in .replit for Replit deploys).
ADMIN_EMAILS=you@example.com

# --- Stripe billing (OPTIONAL — all-or-nothing) -----------------------------
# Billing degrades gracefully when these are unset (Pro upgrades are simply
# disabled). If you set ANY of them, you must set ALL of them or the server
# will refuse to start.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_YEARLY=price_...

# Flutterwave (regional mobile-money / card rail for Africa). Optional; set both
# or neither. FLW_WEBHOOK_HASH is the "Secret hash" you set on the Flutterwave
# dashboard Webhooks page — it arrives in the verif-hash header.
# FLW_SECRET_KEY=FLWSECK_TEST-...
# FLW_WEBHOOK_HASH=your-chosen-secret-hash

# --- Development only --------------------------------------------------------
# Dev-only auth bypass. NEVER set this in production — the server will refuse
# to boot if NODE_ENV=production and this is set.
# ENABLE_TEST_LOGIN=true
# TEST_LOGIN_EMAIL=dev@example.com
